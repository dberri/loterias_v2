APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=loterias
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Where operator alerts (failed backups, failed batches) are sent. Left blank
# here on purpose: blank falls back to MAIL_FROM_ADDRESS, and a blank recipient
# logs an error rather than throwing, so it can never mask the failure it was
# trying to report. Set it for real in any environment you want to hear from.
ALERT_MAIL_TO=
ALERT_SUPPRESSION_MINUTES=10080

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------------------
# Backup object storage (the `backups` disk — Layer 2 of the backup strategy)
#
# The ONLY thing this app uses object storage for: the nightly ExportCorpus
# artifacts (exports/{date}/*.ndjson + manifest.json) and the promoted monthly
# copies (monthly/{YYYY-MM}/). No user uploads, no site assets.
#
# BACKUP_AWS_BUCKET is REQUIRED for backups to work at all. Until it is set the
# nightly export fails — loudly, via AlertNotifier, which is the correct
# failure, but it does mean you have no Layer 2 backup until you set it.
#
# Put this somewhere OTHER than your app host. Layer 2 exists to survive losing
# the Laravel Cloud account itself, so a bucket at the same provider shares the
# failure domain it was created to escape. Two backups with one failure domain
# are one backup.
#
# Any S3-compatible store works — Cloudflare R2, Backblaze B2, DigitalOcean
# Spaces, MinIO — via BACKUP_AWS_ENDPOINT. Non-AWS providers generally need
# BACKUP_AWS_USE_PATH_STYLE_ENDPOINT=true.
#
# Credentials fall back to the AWS_* values above when unset, but prefer
# separate ones: these keys only ever need write access to the backup bucket.
#
# The four optional keys below are COMMENTED OUT on purpose. An .env key that is
# present but empty reads as "" rather than null, which would silently defeat
# the AWS_* fallback and authenticate with an empty credential. Uncomment only
# what you actually set. (config/filesystems.php also guards this with `?:`, but
# absent is still the honest way to say "not configured".)
#
# Retention (35 daily / 12 monthly) is a bucket lifecycle policy, NOT set here —
# see docs/infrastructure/backup-retention.md. It is not applied yet.
# ---------------------------------------------------------------------------
BACKUP_AWS_BUCKET=
BACKUP_AWS_USE_PATH_STYLE_ENDPOINT=false
# BACKUP_AWS_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# BACKUP_AWS_ACCESS_KEY_ID=
# BACKUP_AWS_SECRET_ACCESS_KEY=
# BACKUP_AWS_DEFAULT_REGION=

VITE_APP_NAME="${APP_NAME}"

OPENAI_API_KEY=
OPENAI_ORGANIZATION=
